generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum WorkspacePlan {
  FREE
  PRO

  @@map("workspace_plan")
}

enum WorkspaceRole {
  OWNER
  TEACHER

  @@map("workspace_role")
}

enum EnrollmentStatus {
  ACTIVE
  PAUSED
  ARCHIVED

  @@map("enrollment_status")
}

enum BillingType {
  PACKAGE
  MONTHLY
  PER_LESSON

  @@map("billing_type")
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  RESTORE

  @@map("audit_action")
}

// ON_HOLD hides the student from active lists without soft-deleting
// (distinct from deletedAt, which means "actually removed").
enum StudentStatus {
  ACTIVE
  ON_HOLD
  ARCHIVED

  @@map("student_status")
}

model User {
  id           String    @id @default(uuid())
  email        String    @unique
  passwordHash String
  name         String
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  deletedAt    DateTime?

  memberships  WorkspaceMember[]
  authSessions AuthSession[]
  auditLogs    AuditLog[]

  @@map("users")
}

model Workspace {
  id                        String        @id @default(uuid())
  name                      String
  plan                      WorkspacePlan @default(FREE)
  defaultCurrency           String        @default("EUR")
  cancellationDeadlineHours Int           @default(24)
  createdAt                 DateTime      @default(now())
  updatedAt                 DateTime      @updatedAt
  deletedAt                 DateTime?

  members      WorkspaceMember[]
  authSessions AuthSession[]
  students     Student[]
  parents      Parent[]
  groups       Group[]
  enrollments  Enrollment[]
  auditLogs    AuditLog[]

  @@map("workspaces")
}

// Authorization lives here: a user has a role only within a workspace,
// never globally on User.
model WorkspaceMember {
  id          String        @id @default(uuid())
  workspaceId String
  userId      String
  role        WorkspaceRole
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id])
  user      User      @relation(fields: [userId], references: [id])

  enrollmentsAsTeacher Enrollment[] @relation("EnrollmentTeacher")

  @@unique([workspaceId, userId])
  @@index([userId])
  @@map("workspace_members")
}

// One row per login/registration. Stores only the HMAC of the current
// refresh token; rotation swaps the hash, reuse of a rotated token revokes
// the whole session.
model AuthSession {
  id               String    @id @default(uuid())
  userId           String
  workspaceId      String
  refreshTokenHash String
  expiresAt        DateTime
  lastUsedAt       DateTime  @default(now())
  revokedAt        DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  user      User      @relation(fields: [userId], references: [id])
  workspace Workspace @relation(fields: [workspaceId], references: [id])

  @@index([userId])
  @@index([expiresAt])
  @@map("auth_sessions")
}

model Student {
  id          String    @id @default(uuid())
  workspaceId String
  fullName    String
  // Not unique: siblings may share a contact.
  email       String?
  phone       String?
  timezone    String
  telegramUsername String?
  // Free-text label validated against a curated list at the app layer
  // (@tutorio/validation), not a DB enum — the catalogue is expected to grow.
  subject     String?
  // Default price/currency for this student's enrollments; Enrollment.priceMinor
  // is the per-enrollment override, non-negative (DB CHECK below).
  hourlyRateMinor Int?
  currency    String?
  status      StudentStatus @default(ACTIVE)
  // Free-text labels validated against curated enums at the app layer.
  languageLevel   String?
  knowledgeLevel  String?
  age         Int?
  grade       Int?
  // One of a curated set of bundled illustration keys (validated at the app
  // layer), e.g. "user-3" — never a free-form URL. Null = show initials.
  avatarKey   String?
  notes       String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  workspace   Workspace       @relation(fields: [workspaceId], references: [id])
  enrollments Enrollment[]
  parents     StudentParent[]

  @@index([workspaceId, deletedAt])
  @@index([workspaceId, fullName])
  @@index([workspaceId, updatedAt])
  @@map("students")
}

// Parent/guardian entity, decoupled from Student (a parent may have several
// children in the same workspace). Replaces the old flat
// Student.parentName/parentEmail/parentPhone columns.
model Parent {
  id               String    @id @default(uuid())
  workspaceId      String
  fullName         String
  phone            String?
  telegramUsername String?
  // One of a curated set of bundled illustration keys — see Student.avatarKey.
  avatarKey        String?
  notes            String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  deletedAt        DateTime?

  workspace Workspace       @relation(fields: [workspaceId], references: [id])
  students  StudentParent[]

  @@index([workspaceId, deletedAt])
  @@index([workspaceId, fullName])
  @@index([workspaceId, updatedAt])
  @@map("parents")
}

// Many-to-many join: a student may have several parents, a parent may have
// several students. Removing a link deletes the row outright — there is no
// soft-delete concept for a relationship.
model StudentParent {
  id        String   @id @default(uuid())
  studentId String
  parentId  String
  createdAt DateTime @default(now())

  student Student @relation(fields: [studentId], references: [id])
  parent  Parent  @relation(fields: [parentId], references: [id])

  @@unique([studentId, parentId])
  @@index([studentId])
  @@index([parentId])
  @@map("student_parents")
}

model Group {
  id          String    @id @default(uuid())
  workspaceId String
  name        String
  notes       String?
  // Group-level default price/currency; Enrollment.priceMinor is the
  // per-enrollment override, non-negative (DB CHECK below).
  pricePerLesson Int?
  currency    String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  workspace   Workspace    @relation(fields: [workspaceId], references: [id])
  enrollments Enrollment[]

  @@index([workspaceId, deletedAt])
  @@index([workspaceId, name])
  @@index([workspaceId, updatedAt])
  @@map("groups")
}

// Student participation in a group (groupId set) or individual lessons with a
// teacher (groupId null). All financial entities in later stages hang off the
// enrollment, never off the group.
model Enrollment {
  id                        String           @id @default(uuid())
  workspaceId               String
  studentId                 String
  groupId                   String?
  // The teacher is a workspace member, not a bare user: authorization and
  // teacher identity are workspace-scoped.
  teacherId                 String
  status                    EnrollmentStatus @default(ACTIVE)
  billingType               BillingType      @default(PACKAGE)
  // Price per lesson in minor units of `currency`; non-negative (DB CHECK).
  priceMinor                Int
  currency                  String
  // Overrides Workspace.cancellationDeadlineHours; null = inherit the default.
  cancellationDeadlineHours Int?
  createdAt                 DateTime         @default(now())
  updatedAt                 DateTime         @updatedAt
  deletedAt                 DateTime?

  workspace Workspace       @relation(fields: [workspaceId], references: [id])
  student   Student         @relation(fields: [studentId], references: [id])
  group     Group?          @relation(fields: [groupId], references: [id])
  teacher   WorkspaceMember @relation("EnrollmentTeacher", fields: [teacherId], references: [id])

  // Uniqueness among non-deleted rows only (one active enrollment per
  // student+group, one active individual enrollment per student+teacher) is
  // enforced by partial unique indexes added as raw SQL in the Stage 2
  // migration — Prisma cannot express partial indexes.
  @@index([workspaceId, deletedAt])
  @@index([studentId])
  @@index([groupId])
  @@index([teacherId])
  @@map("enrollments")
}

// Append-only: no updatedAt/deletedAt on purpose. actorId is null for
// system-initiated changes (cron jobs, migrations).
model AuditLog {
  id          String      @id @default(uuid())
  workspaceId String
  actorId     String?
  entity      String
  entityId    String
  action      AuditAction
  diff        Json?
  createdAt   DateTime    @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id])
  actor     User?     @relation(fields: [actorId], references: [id])

  @@index([workspaceId, createdAt])
  @@index([workspaceId, entity, entityId])
  @@map("audit_logs")
}
