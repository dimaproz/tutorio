# PostgreSQL (Railway: Variables → DATABASE_URL of the Postgres service)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/tutorio?schema=public"

# HTTP
PORT=4000
# Allowed CORS origins, comma-separated (never falls back to "*")
WEB_ORIGIN=http://localhost:3000

# Auth — generate each secret with: openssl rand -hex 32 (min 32 chars, must differ)
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d
JWT_ISSUER=tutorio-api
JWT_AUDIENCE=tutorio-clients

# Rate limiting (requests per minute per client; raise only for test runs)
# THROTTLE_AUTH_LIMIT=5
# THROTTLE_REFRESH_LIMIT=20

# Sentry (empty = disabled)
SENTRY_DSN=
