# PostgreSQL (Railway: Variables → DATABASE_URL сервиса Postgres)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/tutorio?schema=public"

# HTTP
PORT=4000
# Разрешённые origin'ы для CORS, через запятую
WEB_ORIGIN=http://localhost:3000

# Auth
JWT_SECRET=dev-secret-change-me
JWT_ACCESS_TTL=15m

# Sentry (пусто = выключено)
SENTRY_DSN=
