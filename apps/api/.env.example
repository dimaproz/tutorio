# PostgreSQL (Railway: Variables → DATABASE_URL of the Postgres service)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/tutorio?schema=public"

# HTTP
PORT=4000
# Allowed CORS origins, comma-separated
WEB_ORIGIN=http://localhost:3000

# Auth
JWT_SECRET=dev-secret-change-me
JWT_ACCESS_TTL=15m

# Sentry (empty = disabled)
SENTRY_DSN=
